{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillOutput",
  "description": "Schema for skill execution output",
  "type": "object",
  "properties": {
    "@context": { "type": "string" },
    "@id": { "type": "string" },
    "@type": { "type": "string", "enum": ["SkillOutput"] },
    "status": { "type": "string", "enum": ["success", "error", "partial"] },
    "result": { "type": "object" },
    "error": { "type": "string" },
    "duration_ms": { "type": "integer", "minimum": 0 }
  },
  "required": ["status"]
}
